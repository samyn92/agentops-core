{
  "name": "@agenticops/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Agent runtime container: Pi SDK + HTTP server + operator extension",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:daemon": "node dist/agent-server.js",
    "start:task": "node dist/agent-task.js",
    "dev": "tsx src/agent-server.ts",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@mariozechner/pi-agent-core": "^0.65.0",
    "@mariozechner/pi-ai": "^0.65.0",
    "@kubernetes/client-node": "^1.0.0",
    "express": "^4.21.0",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/express": "^4.17.21",
    "eslint": "^9.0.0"
  }
}
